# AIvest.ru — переменные окружения
# Скопируйте этот файл как .env и заполните значения

# ── Сервер ──
PORT=3000
SITE_URL=https://aivest.ru

# ── Email (SMTP) — рекомендуется Яндекс 360 или Mail.ru ──
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=info@aivest.ru
SMTP_PASS=ВАШ_ПАРОЛЬ_ПРИЛОЖЕНИЯ

# ── Уведомления ──
ADMIN_EMAIL=admin@aivest.ru
SUPPORT_EMAIL=support@aivest.ru

# ── Безопасность ──
# Сгенерируйте случайный ключ: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_KEY=замените_на_случайный_ключ_32_символа
